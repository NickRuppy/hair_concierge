{
  "name": "hair-concierge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:worktree": "node scripts/worktree-dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "ci:verify": "npm run typecheck && npm run lint && npm run build",
    "worktree:new": "node scripts/worktree-new.mjs",
    "worktree:list": "git worktree list",
    "worktree:prune": "git worktree prune",
    "test:extract": "tsx scripts/extract-qa-fixtures.ts",
    "test:comparelab:extract": "tsx scripts/extract-comparelab-prompts.ts",
    "test:qa": "playwright test qa-validation",
    "test:chat": "tsx scripts/eval-chat/run.ts --skip-judge",
    "test:chat:judge": "tsx scripts/eval-chat/run.ts",
    "test:chat:langfuse": "tsx scripts/eval-chat/run.ts --langfuse-publish",
    "test:node": "tsx --test tests/*.test.ts tests/*.test.tsx",
    "test:agent": "tsx --test tests/agent-guidance.spec.ts tests/agent-guidance-tracing.spec.ts tests/agentic-tool-loop.spec.ts tests/agent-route-packet.spec.ts tests/agent-get-user-context.spec.ts tests/agent-select-products-tool.spec.ts tests/agent-routine-tool.spec.ts tests/agent-shadow.spec.ts tests/agent-production-chat-pipeline.spec.ts tests/agent-final-render-prompt.spec.ts",
    "test:playwright:contracts": "playwright test tests/chat-debug-trace.spec.ts tests/conditioner-reranker.spec.ts tests/conversation-state.spec.ts tests/leave-in-decision.spec.ts tests/mask-flow.spec.ts tests/routine-planner.spec.ts tests/shampoo-flow.spec.ts tests/stripe-gating.spec.ts tests/stripe-intervals.spec.ts tests/stripe-webhook-handlers.spec.ts tests/user-memory.spec.ts --project=chromium",
    "test:contracts": "npm run test:node && npm run test:agent && npm run test:playwright:contracts",
    "test:chat:ci": "tsx scripts/eval-chat/run.ts --skip-judge --ci-smoke",
    "test:retrieval:ci": "tsx scripts/eval-retrieval.ts --hybrid-only --min-hybrid-ndcg10 0.72 --min-hybrid-recall20 0.88 --skip-unannotated-gold-set",
    "langfuse:sync-prompts": "tsx scripts/langfuse/sync-prompts.ts",
    "langfuse:seed-datasets": "tsx scripts/langfuse/seed-datasets.ts",
    "langfuse:setup-review-queues": "tsx scripts/langfuse/setup-review-queues.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@langfuse/client": "^5.3.0",
    "@langfuse/openai": "^5.3.0",
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.1.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@sentry/nextjs": "^10.53.1",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.5.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.95.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cohere-ai": "^8.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "openai": "^6.37.0",
    "pdf-parse": "^2.4.5",
    "posthog-js": "^1.373.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "start-server-and-test": "^2.1.5",
    "supabase": "^2.98.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "overrides": {
    "dompurify": "3.4.0",
    "fast-xml-parser": "5.7.2",
    "follow-redirects": "1.16.0",
    "postcss": "8.5.10",
    "protobufjs": "7.5.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
