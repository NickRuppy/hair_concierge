{
  "name": "tombot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:worktree": "node scripts/worktree-dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "ci:verify": "npm run typecheck && npm run lint && npm run build",
    "worktree:new": "node scripts/worktree-new.mjs",
    "worktree:list": "git worktree list",
    "worktree:prune": "git worktree prune",
    "test:extract": "tsx scripts/extract-qa-fixtures.ts",
    "test:qa": "playwright test qa-validation",
    "test:chat": "tsx scripts/eval-chat/run.ts --skip-judge",
    "test:chat:judge": "tsx scripts/eval-chat/run.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.48.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cohere-ai": "^7.20.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "openai": "^6.18.0",
    "pdf-parse": "^2.4.5",
    "posthog-js": "^1.347.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.32",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.2",
    "start-server-and-test": "^2.1.5",
    "supabase": "^2.75.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
