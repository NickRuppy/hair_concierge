# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.playwright-user-data/
.playwright-mcp/
/test-results/
/tests/results/*.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.swp

# worktrees
.worktrees/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# claude code (local settings only — shared settings.json is tracked)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/local/
.claude/skills/local/
.claude/skills/challenge-me/

# vercel
.vercel

# data files (books, transcripts, products)
/data/
!/data/
/data/*
!/data/agent-guidance/
!/data/agent-guidance/**
!/data/agent-v2/
!/data/agent-v2/**
!/data/product-metadata-audit/
!/data/product-metadata-audit/**
!/data/product-additions/
!/data/product-additions/**
!/data/product-catalog-normalization.json
!/data/product-catalog-normalization.schema.json
!/data/product-catalog-snapshot.json
*.docx

# python
__pycache__/
*.pyc

# typescript
*.tsbuildinfo
next-env.d.ts

# ux audit reports (local artifacts)
ux-audits/
/docs/marketing-strategy.md
/docs/routine-trigger-evidence-audit.md

# test scripts & artifacts (ad-hoc, may contain credentials)
test-*.mjs
test-*.ts
test-*.json
fix-test-user.mjs
test-screenshots*/
*.png
!public/images/**/*.png
/daily-briefing-*.md

# local eval / compare-lab artifacts
/tmp/

# local Clawpatch review artifacts
/.clawpatch/
/clawpatch-report.md
/clawpatch-summary.md
*.claude-code-review*.md

# Affiliate link research artefacts (regenerated; safe to delete)
!/data/affiliate-research/
/data/affiliate-research/*
!/data/affiliate-research/.gitkeep
