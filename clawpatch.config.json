{
  "schemaVersion": 1,
  "stateDir": ".clawpatch",
  "include": ["**/*"],
  "exclude": [
    "node_modules/**",
    ".next/**",
    "out/**",
    "dist/**",
    "build/**",
    "target/**",
    ".build/**",
    ".git/**",
    ".clawpatch/**",
    ".worktrees/**",
    ".tmp-previews/**",
    "coverage/**",
    "test-results/**",
    "tests/results/**",
    "tmp/**",
    "data/**",
    ".env*",
    "*.docx",
    "*.pdf",
    "*.png"
  ],
  "provider": {
    "name": "codex",
    "model": null
  },
  "commands": {
    "typecheck": "npm run typecheck",
    "lint": "npm run lint",
    "format": null,
    "test": "npm run test:node"
  },
  "review": {
    "maxContextFiles": 24,
    "maxOwnedFiles": 12,
    "maxFindingsPerFeature": 10,
    "minConfidenceToFix": "medium"
  },
  "git": {
    "requireCleanWorktreeForFix": true,
    "commit": false,
    "openPr": false
  }
}
